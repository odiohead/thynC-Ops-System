generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "wiki"]
}

model HiraHospital {
  id              Int      @id @default(autoincrement())
  hiraId          String   @unique @map("hira_id")
  name            String   @map("name")
  typeCode        String   @map("type_code")
  typeName        String   @map("type_name")
  sidoCode        String   @map("sido_code")
  sidoName        String   @map("sido_name")
  sigunguCode     String   @map("sigungu_code")
  sigunguName     String   @map("sigungu_name")
  eupmyeondong    String?  @map("eupmyeondong")
  postalCode      String?  @map("postal_code")
  address         String?  @map("address")
  phone           String?  @map("phone")
  homepage        String?  @map("homepage")
  totalDoctors    Int?     @map("total_doctors")
  openedAt        String?  @map("opened_at")
  coordinateX     String?  @map("coordinate_x")
  coordinateY     String?  @map("coordinate_y")
  mdeptGdrCnt     Int?     @map("mdept_gdr_cnt")
  mdeptIntnCnt    Int?     @map("mdept_intn_cnt")
  mdeptResdntCnt  Int?     @map("mdept_resdnt_cnt")
  mdeptSdrCnt     Int?     @map("mdept_sdr_cnt")
  detyGdrCnt      Int?     @map("dety_gdr_cnt")
  detyIntnCnt     Int?     @map("dety_intn_cnt")
  detyResdntCnt   Int?     @map("dety_resdnt_cnt")
  detySdrCnt      Int?     @map("dety_sdr_cnt")
  cmdcGdrCnt      Int?     @map("cmdc_gdr_cnt")
  cmdcIntnCnt     Int?     @map("cmdc_intn_cnt")
  cmdcResdntCnt   Int?     @map("cmdc_resdnt_cnt")
  cmdcSdrCnt      Int?     @map("cmdc_sdr_cnt")
  midwifeCnt      Int?     @map("midwife_cnt")
  createdAt       DateTime @default(now()) @map("created_at")
  hospital        Hospital?

  @@map("hira_hospitals")
  @@schema("public")
}

model Hospital {
  id                Int      @id @default(autoincrement())
  hospitalCode      String   @unique @map("hospital_code")
  hiraId            String?  @unique @map("hira_id")
  hiraHospitalName  String   @map("hira_hospital_name")
  hospitalName      String   @map("hospital_name")
  type              String   @map("type")
  sidoCode       String?  @map("sido_code")
  sidoName       String?  @map("sido_name")
  sigunguCode    String?  @map("sigungu_code")
  sigunguName    String?  @map("sigungu_name")
  eupmyeondong   String?  @map("eupmyeondong")
  postalCode     String?  @map("postal_code")
  address        String?  @map("address")
  coordinateX    String?  @map("coordinate_x")
  coordinateY    String?  @map("coordinate_y")
  status         String   @map("status")
  introType      String?  @map("intro_type")
  introBeds      Int?     @map("intro_beds")
  contractDate   DateTime? @map("contract_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  hiraHospital        HiraHospital? @relation(fields: [hiraId], references: [hiraId])
  daewoongAssignments DaewoongHospitalAssignment[]
  projects            Project[]
  meta                HospitalMeta?
  hospitalDevices     HospitalDevice[]
  siteVisits          SiteVisit[]
  introTypes          HospitalIntroType[]
  installPlans        InstallPlan[]
  maintenances        Maintenance[]
  consultationQueues  ConsultationQueue[]
  tasks               Task[]

  @@map("hospitals")
  @@schema("public")
}

model HospitalIntroType {
  id           Int        @id @default(autoincrement())
  hospitalId   Int        @map("hospital_id")
  statusCodeId Int        @map("status_code_id")
  hospital     Hospital   @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  statusCode   StatusCode @relation(fields: [statusCodeId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, statusCodeId])
  @@map("hospital_intro_types")
  @@schema("public")
}

model DaewoongHospitalAssignment {
  id             String   @id @default(uuid())
  hospitalCode   String   @map("hospital_code")
  assignedUserId String   @map("assigned_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  hospital       Hospital @relation(fields: [hospitalCode], references: [hospitalCode])
  assignedUser   User     @relation(fields: [assignedUserId], references: [id])

  @@unique([hospitalCode, assignedUserId])
  @@map("daewoong_hospital_assignments")
  @@schema("public")
}

model StatusCode {
  id        Int      @id @default(autoincrement())
  name      String   @map("name")
  value     String?  @map("value")
  order     Int      @default(0) @map("order")
  color     String?  @map("color")
  category  String   @default("HOSPITAL") @map("category")
  createdAt DateTime @default(now()) @map("created_at")
  siteVisits                    SiteVisit[]
  hospitalIntroTypes            HospitalIntroType[]
  introTypeProjects             Project[]              @relation("ProjectIntroType")
  consultationTypeQueues        ConsultationQueue[]    @relation("ConsultationTypeQueue")
  documentTypeQueues            ConsultationQueue[]    @relation("DocumentTypeQueue")
  maintenanceTypes              Maintenance[]          @relation("MaintenanceType")
  maintenanceStatuses           Maintenance[]          @relation("MaintenanceStatus")

  @@unique([name, category])
  @@map("status_codes")
  @@schema("public")
}

model ConsultationQueue {
  id                  Int         @id @default(autoincrement())
  hospitalCode        String?     @map("hospital_code")
  consultationTypeId  Int?        @map("consultation_type_id")
  documentTypeId      Int?        @map("document_type_id")
  conclusion          String?
  chatHistory         Json        @default("[]") @map("chat_history")
  aiSummary           String?     @map("ai_summary")
  status              String      @default("PENDING")
  consultedById       String      @map("consulted_by_id")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @default(now()) @map("updated_at")

  hospital            Hospital?   @relation(fields: [hospitalCode], references: [hospitalCode])
  consultationType    StatusCode? @relation("ConsultationTypeQueue", fields: [consultationTypeId], references: [id])
  documentType        StatusCode? @relation("DocumentTypeQueue", fields: [documentTypeId], references: [id])
  consultedBy         User        @relation(fields: [consultedById], references: [id])

  @@map("consultation_queue")
  @@schema("public")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  VIEWER

  @@schema("public")
}

model Organization {
  id          Int          @id @default(autoincrement())
  name        String
  code        String       @unique
  isActive    Boolean      @default(true) @map("is_active")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  users       User[]
  departments Department[]

  @@map("organizations")
  @@schema("public")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  name           String
  phone          String
  role           Role          @default(USER)
  isActive       Boolean       @default(true) @map("is_active")
  organizationId Int?          @map("organization_id")
  departmentId   Int?          @map("department_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  lastLoginAt    DateTime?     @map("last_login_at")
  organization            Organization?                @relation(fields: [organizationId], references: [id])
  department              Department?                  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  fieldEngineers          FieldEngineer[]
  daewoongSiteVisits      SiteVisit[]                  @relation("SiteVisitDaewoongUser")
  hospitalAssignments     DaewoongHospitalAssignment[]
  projectAssignees        ProjectAssignee[]
  installPlanAssignees    InstallPlanAssignee[]
  siteVisitAssignees      SiteVisitAssignee[]
  maintenanceAssignees    MaintenanceAssignee[]
  consultationQueues      ConsultationQueue[]
  wikiPagesAuthored       WikiPage[]                   @relation("WikiPageAuthor")
  wikiPagesEdited         WikiPage[]                   @relation("WikiPageLastEditor")
  wikiAttachmentsUploaded WikiAttachment[]             @relation("WikiAttachmentUploader")
  wikiPageRefsCreated     WikiPageReference[]          @relation("WikiPageRefCreator")
  wikiFavorites           WikiFavorite[]               @relation("WikiFavoriteUser")
  wikiViewLogs            WikiViewLog[]                @relation("WikiViewLogUser")
  wikiVersionsSaved       WikiVersion[]                @relation("WikiVersionSaver")
  wikiCommentsAuthored    WikiComment[]                @relation("WikiCommentAuthor")

  @@map("users")
  @@schema("public")
}

model Department {
  id             Int          @id @default(autoincrement())
  name           String       @db.VarChar(100)
  organizationId Int          @map("organization_id")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]

  @@map("departments")
  @@schema("public")
}

model FieldEngineer {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  workType  String   @default("PROJECT") @map("work_type")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workType])
  @@index([workType])
  @@map("field_engineers")
  @@schema("public")
}

model DeviceInfo {
  id          Int      @id @default(autoincrement())
  deviceModel String   @unique @map("device_model")
  deviceName  String   @map("device_name")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  devices         ProjectDevice[]
  hospitalDevices HospitalDevice[]

  @@map("device_info")
  @@schema("public")
}

model Contractor {
  id             Int       @id @default(autoincrement())
  code           String    @unique @map("code")
  name           String    @map("name")
  bizRegNumber   String?   @map("biz_reg_number")
  managerName    String?   @map("manager_name")
  managerPhone   String?   @map("manager_phone")
  managerEmail   String?   @map("manager_email")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  projects       Project[]

  @@map("constructors")
  @@schema("public")
}

model BuildStatus {
  id        Int       @id @default(autoincrement())
  label     String    @map("label")
  color     String?   @map("color")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  projects  Project[]

  @@map("build_statuses")
  @@schema("public")
}

model Project {
  id                  Int          @id @default(autoincrement())
  projectCode         String       @unique @map("project_code")
  projectName         String       @map("project_name")
  hospitalCode        String       @map("hospital_code")
  orderNumber         Int          @map("order_number")
  contractDate        DateTime?    @map("contract_date")
  contractType        String?      @map("contract_type")
  wardCount           Int?         @map("ward_count")
  bedCount            Int?         @map("bed_count")
  gatewayCount        Int?         @map("gateway_count")
  hasSurvey           Boolean      @default(false) @map("has_survey")
  hasOrder            Boolean      @default(false) @map("has_order")
  builderNameManual   String?      @map("builder_name_manual")
  constructorId       Int?         @map("constructor_id")
  startDate           DateTime?    @map("start_date")
  endDateExpected     DateTime?    @map("end_date_expected")
  buildStatusId       Int?         @map("build_status_id")
  introTypeId         Int?         @map("intro_type_id")
  issueNote           String?      @db.Text @map("issue_note")
  remark              String?      @map("remark")
  driveFolderId       String?      @map("drive_folder_id")
  calendarEventId     String?      @map("calendar_event_id")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  hospital            Hospital     @relation(fields: [hospitalCode], references: [hospitalCode])
  contractor          Contractor?  @relation(fields: [constructorId], references: [id])
  buildStatus         BuildStatus? @relation(fields: [buildStatusId], references: [id])
  introType           StatusCode?  @relation("ProjectIntroType", fields: [introTypeId], references: [id])
  devices             ProjectDevice[]
  files               ProjectFile[]
  assignees           ProjectAssignee[]

  @@map("projects")
  @@schema("public")
}

model ProjectDevice {
  id           Int        @id @default(autoincrement())
  projectId    Int        @map("project_id")
  deviceInfoId Int        @map("device_info_id")
  quantity     Int        @default(0) @map("quantity")
  createdAt    DateTime   @default(now()) @map("created_at")
  project      Project    @relation(fields: [projectId], references: [id])
  deviceInfo   DeviceInfo @relation(fields: [deviceInfoId], references: [id])

  @@unique([projectId, deviceInfoId])
  @@map("project_devices")
  @@schema("public")
}

model HospitalDevice {
  id           Int        @id @default(autoincrement())
  hospitalCode String     @map("hospital_code")
  hospital     Hospital   @relation(fields: [hospitalCode], references: [hospitalCode])
  deviceInfoId Int        @map("device_info_id")
  deviceInfo   DeviceInfo @relation(fields: [deviceInfoId], references: [id])
  quantity     Int        @default(0) @map("quantity")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([hospitalCode, deviceInfoId])
  @@map("hospital_devices")
  @@schema("public")
}

model HospitalMeta {
  id                     Int      @id @default(autoincrement())
  hospitalCode           String   @unique @map("hospital_code")
  hospital               Hospital @relation(fields: [hospitalCode], references: [hospitalCode])
  driveProjectFolderId   String?  @map("drive_project_folder_id")
  driveStatusFileId      String?  @map("drive_status_file_id")
  driveInstallPlanFileId String?  @map("drive_install_plan_file_id")
  remoteAccessUrl        String?  @map("remote_access_url")
  remoteControlUrl       String?  @map("remote_control_url")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("hospital_meta")
  @@schema("public")
}

model ProjectFile {
  id           Int      @id @default(autoincrement())
  projectId    Int      @map("project_id")
  fileCategory String   @map("file_category")
  fileName     String   @map("file_name")
  driveFileId  String   @map("drive_file_id")
  driveUrl     String   @map("drive_url")
  s3Key        String?  @map("s3_key")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  project      Project  @relation(fields: [projectId], references: [id])

  @@map("project_files")
  @@schema("public")
}

model SiteVisit {
  id              Int            @id @default(autoincrement())
  siteVisitCode   String?        @unique @map("site_visit_code") @db.VarChar(50)
  hospitalCode    String         @map("hospital_code")
  daewoongUserId  String?        @map("daewoong_user_id")
  requestDate     DateTime?      @map("request_date")
  visitDate       DateTime?      @map("visit_date")
  replyDate       DateTime?      @map("reply_date")
  statusId        Int?           @map("status_id")
  installPlanUrl    String?  @map("install_plan_url")
  installPlanFileId String?  @map("install_plan_file_id")
  floorPlanUrl      String?  @map("floor_plan_url")
  floorPlanFileId   String?  @map("floor_plan_file_id")
  installPlanS3Key  String?  @map("install_plan_s3_key")
  floorPlanS3Key    String?  @map("floor_plan_s3_key")
  notes           String?        @db.Text @map("notes")
  calendarEventId String?        @map("calendar_event_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  hospital      Hospital         @relation(fields: [hospitalCode], references: [hospitalCode])
  daewoongUser  User?            @relation("SiteVisitDaewoongUser", fields: [daewoongUserId], references: [id])
  status        StatusCode?      @relation(fields: [statusId], references: [id])
  files         SiteVisitFile[]
  assignees     SiteVisitAssignee[]
  queue         SiteVisitQueue?

  @@map("site_visits")
  @@schema("public")
}

model SiteVisitFile {
  id           Int       @id @default(autoincrement())
  siteVisitId  Int       @map("site_visit_id")
  fileCategory String    @map("file_category")
  fileName     String    @map("file_name")
  s3Key        String    @map("s3_key")
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  siteVisit    SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)

  @@map("site_visit_files")
  @@schema("public")
}

model InstallPlan {
  id           Int       @id @default(autoincrement())
  planCode     String?   @unique @map("plan_code")
  hospitalCode String?   @map("hospital_code")
  requestDate  DateTime? @map("request_date") @db.Date
  writeStatus  String    @default("-") @map("write_status")
  replyStatus  String    @default("-") @map("reply_status")
  replyDate    DateTime? @map("reply_date") @db.Date
  note         String?

  hospital  Hospital?         @relation(fields: [hospitalCode], references: [hospitalCode])
  files     InstallPlanFile[]
  assignees InstallPlanAssignee[]
  queueItem InstallPlanQueue?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("install_plans")
  @@schema("public")
}

model InstallPlanFile {
  id            Int         @id @default(autoincrement())
  installPlanId Int         @map("install_plan_id")
  fileCategory  String      @map("file_category")
  fileName      String      @map("file_name")
  s3Key         String      @map("s3_key")
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  installPlan   InstallPlan @relation(fields: [installPlanId], references: [id], onDelete: Cascade)

  @@map("install_plan_files")
  @@schema("public")
}

model HiraSyncJob {
  id         Int           @id @default(autoincrement())
  startedAt  DateTime      @default(now()) @map("started_at")
  endedAt    DateTime?     @map("ended_at")
  status     String        @default("running") @map("status")
  totalCount Int           @default(0) @map("total_count")
  logs       HiraSyncLog[]

  @@map("hira_sync_jobs")
  @@schema("public")
}

model ProjectAssignee {
  id          Int      @id @default(autoincrement())
  projectCode String   @map("project_code")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectCode], references: [projectCode], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectCode, userId])
  @@map("project_assignees")
  @@schema("public")
}

model InstallPlanAssignee {
  id            Int         @id @default(autoincrement())
  installPlanId Int         @map("install_plan_id")
  userId        String      @map("user_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  installPlan   InstallPlan @relation(fields: [installPlanId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([installPlanId, userId])
  @@map("install_plan_assignees")
  @@schema("public")
}

model SiteVisitAssignee {
  id          Int       @id @default(autoincrement())
  siteVisitId Int       @map("site_visit_id")
  userId      String    @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  siteVisit   SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteVisitId, userId])
  @@map("site_visit_assignees")
  @@schema("public")
}

model HiraSyncLog {
  id        Int         @id @default(autoincrement())
  jobId     Int         @map("job_id")
  job       HiraSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type      String      @map("type")
  message   String      @map("message")
  stats     Json?       @map("stats")
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("hira_sync_logs")
  @@schema("public")
}

model InstallPlanQueue {
  id              Int          @id @default(autoincrement())
  gmailMessageId  String       @unique @map("gmail_message_id")
  receivedAt      DateTime     @map("received_at")
  hospitalNameRaw String       @map("hospital_name_raw")
  requestDate     DateTime?    @map("request_date")
  managerName     String       @map("manager_name")
  managerPhone    String       @map("manager_phone")
  managerEmail    String       @map("manager_email")
  totalBeds       String       @map("total_beds")
  address         String       @default("") @db.Text
  model           String
  rawBody         String       @map("raw_body") @db.Text
  fileUrl         String       @default("") @map("file_url") @db.Text
  status          String       @default("pending")
  installPlanId   Int?         @unique @map("install_plan_id")
  installPlan     InstallPlan? @relation(fields: [installPlanId], references: [id])
  createdAt       DateTime     @default(now()) @map("created_at")

  @@map("install_plan_queue")
  @@schema("public")
}

model SiteVisitQueue {
  id              Int        @id @default(autoincrement())
  gmailMessageId  String     @unique @map("gmail_message_id")
  receivedAt      DateTime   @map("received_at")
  hospitalNameRaw String     @map("hospital_name_raw")
  requestDate     DateTime?  @map("request_date")
  managerName     String     @map("manager_name")
  managerPhone    String     @map("manager_phone")
  managerEmail    String     @map("manager_email")
  totalBeds       String     @map("total_beds")
  address         String     @default("") @db.Text
  model           String
  rawBody         String     @map("raw_body") @db.Text
  fileUrl         String     @default("") @map("file_url") @db.Text
  status          String     @default("pending")
  siteVisitId     Int?       @unique @map("site_visit_id")
  siteVisit       SiteVisit? @relation(fields: [siteVisitId], references: [id])
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("site_visit_queue")
  @@schema("public")
}

model AppSetting {
  key   String @id
  value String @default("")

  @@map("app_settings")
  @@schema("public")
}

model NavMenuItem {
  id              Int      @id @default(autoincrement())
  menuKey         String   @unique @map("menu_key") @db.VarChar(100)
  label           String   @map("label") @db.VarChar(200)
  href            String   @map("href") @db.VarChar(200)
  iconKey         String?  @map("icon_key") @db.VarChar(50)
  parentKey       String?  @map("parent_key") @db.VarChar(100)
  allowedRoles    String[] @default([]) @map("allowed_roles")
  allowedOrgCodes String[] @default([]) @map("allowed_org_codes")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("nav_menu_items")
  @@schema("public")
}

model Task {
  id           Int       @id @default(autoincrement())
  taskCode     String    @unique @map("task_code") @db.VarChar(20)
  taskType     String    @map("task_type") @db.VarChar(20)
  refCode      String    @map("ref_code") @db.VarChar(50)
  hospitalCode String?   @map("hospital_code") @db.VarChar(50)
  title        String?
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  hospital Hospital? @relation(fields: [hospitalCode], references: [hospitalCode])

  @@index([taskType])
  @@index([refCode])
  @@index([hospitalCode])
  @@map("tasks")
  @@schema("public")
}

model Maintenance {
  id                Int       @id @default(autoincrement())
  maintenanceCode   String?   @unique @map("maintenance_code")
  hospitalCode      String    @map("hospital_code")
  typeId            Int?      @map("type_id")
  statusId          Int?      @map("status_id")
  priority          String    @default("보통") @map("priority")
  title             String    @map("title")
  reporterName      String?   @map("reporter_name")
  isRemote          Boolean   @default(false) @map("is_remote")
  reportedAt        DateTime? @map("reported_at") @db.Date
  visitDate         DateTime? @map("visit_date") @db.Date
  resolvedAt        DateTime? @map("resolved_at") @db.Date
  symptoms          String?   @db.Text @map("symptoms")
  cause             String?   @db.Text @map("cause")
  resolution        String?   @db.Text @map("resolution")
  notes             String?   @db.Text @map("notes")
  calendarEventId   String?   @map("calendar_event_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  hospital   Hospital    @relation(fields: [hospitalCode], references: [hospitalCode])
  type       StatusCode? @relation("MaintenanceType", fields: [typeId], references: [id])
  status     StatusCode? @relation("MaintenanceStatus", fields: [statusId], references: [id])
  assignees  MaintenanceAssignee[]
  files      MaintenanceFile[]

  @@map("maintenances")
  @@schema("public")
}

model MaintenanceAssignee {
  id            Int         @id @default(autoincrement())
  maintenanceId Int         @map("maintenance_id")
  userId        String      @map("user_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([maintenanceId, userId])
  @@map("maintenance_assignees")
  @@schema("public")
}

model MaintenanceFile {
  id            Int         @id @default(autoincrement())
  maintenanceId Int         @map("maintenance_id")
  fileCategory  String      @map("file_category")
  fileName      String      @map("file_name")
  s3Key         String      @map("s3_key")
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@map("maintenance_files")
  @@schema("public")
}

model AuditLog {
  id            Int       @id @default(autoincrement())

  actorId       String?   @map("actor_id")
  actorEmail    String?   @map("actor_email")
  actorName     String?   @map("actor_name")
  actorRole     String?   @map("actor_role")

  action        String
  resource      String
  resourceId    String?   @map("resource_id")
  resourceLabel String?   @map("resource_label")

  before        Json?
  after         Json?

  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")

  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([resource, resourceId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("public")
}

// ============================================================
// Wiki 모듈 (사내 위키)
//
// - 별도 PostgreSQL 스키마 `wiki`에 격리
// - FK 참조 방향: wiki.* → public.*  (반대 금지)
// - 코드 의존성: app/wiki/*, lib/wiki/* → 메인 OK / 메인 → 위키 금지
// ============================================================

model WikiPage {
  id           String   @id @default(uuid())
  parentId     String?  @map("parent_id")
  title        String
  slug         String?
  contentJson  Json     @map("content_json")
  isPublished  Boolean  @default(true) @map("is_published")
  sortOrder    Int      @default(0) @map("sort_order")
  authorId     String   @map("author_id")
  lastEditorId String?  @map("last_editor_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  plainText   String              @default("") @map("plain_text")

  parent      WikiPage?           @relation("WikiPageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    WikiPage[]          @relation("WikiPageTree")
  author      User                @relation("WikiPageAuthor", fields: [authorId], references: [id])
  lastEditor  User?               @relation("WikiPageLastEditor", fields: [lastEditorId], references: [id])
  attachments WikiAttachment[]
  references  WikiPageReference[]
  tags        WikiPageTag[]
  favorites   WikiFavorite[]
  viewLogs    WikiViewLog[]
  versions    WikiVersion[]
  comments    WikiComment[]

  @@index([parentId, sortOrder])
  @@index([updatedAt(sort: Desc)])
  @@index([authorId])
  @@map("wiki_pages")
  @@schema("wiki")
}

model WikiAttachment {
  id         String   @id @default(uuid())
  pageId     String   @map("page_id")
  fileName   String   @map("file_name")
  s3Key      String   @unique @map("s3_key")
  size       Int
  mimeType   String   @map("mime_type")
  uploaderId String   @map("uploader_id")
  createdAt  DateTime @default(now()) @map("created_at")

  page     WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  uploader User     @relation("WikiAttachmentUploader", fields: [uploaderId], references: [id])

  @@index([pageId])
  @@map("wiki_attachments")
  @@schema("wiki")
}

model WikiPageReference {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  refType     String   @map("ref_type")
  refCode     String   @map("ref_code")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User     @relation("WikiPageRefCreator", fields: [createdById], references: [id])

  @@unique([pageId, refType, refCode])
  @@index([refType, refCode])
  @@index([pageId])
  @@map("wiki_page_references")
  @@schema("wiki")
}

model WikiTag {
  id        String        @id @default(uuid())
  name      String        @unique
  color     String?
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at")

  pages WikiPageTag[]

  @@map("wiki_tags")
  @@schema("wiki")
}

model WikiPageTag {
  pageId  String   @map("page_id")
  tagId   String   @map("tag_id")
  addedAt DateTime @default(now()) @map("added_at")

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tag  WikiTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([pageId, tagId])
  @@index([tagId])
  @@map("wiki_page_tags")
  @@schema("wiki")
}

model WikiFavorite {
  userId    String   @map("user_id")
  pageId    String   @map("page_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User     @relation("WikiFavoriteUser", fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@id([userId, pageId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("wiki_favorites")
  @@schema("wiki")
}

model WikiViewLog {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  pageId   String   @map("page_id")
  viewedAt DateTime @default(now()) @map("viewed_at")

  user User     @relation("WikiViewLogUser", fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt(sort: Desc)])
  @@index([pageId])
  @@map("wiki_view_logs")
  @@schema("wiki")
}

model WikiVersion {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  title       String
  contentJson Json     @map("content_json")
  savedById   String   @map("saved_by_id")
  savedAt     DateTime @default(now()) @map("saved_at")

  page    WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  savedBy User     @relation("WikiVersionSaver", fields: [savedById], references: [id])

  @@index([pageId, savedAt(sort: Desc)])
  @@map("wiki_versions")
  @@schema("wiki")
}

model WikiComment {
  id        String   @id @default(uuid())
  pageId    String   @map("page_id")
  authorId  String   @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User     @relation("WikiCommentAuthor", fields: [authorId], references: [id])

  @@index([pageId, createdAt])
  @@index([authorId])
  @@map("wiki_comments")
  @@schema("wiki")
}
