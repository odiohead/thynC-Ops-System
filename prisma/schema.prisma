generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "wiki"]
}

model HiraHospital {
  id              Int      @id @default(autoincrement())
  hiraId          String   @unique @map("hira_id")
  name            String   @map("name")
  typeCode        String   @map("type_code")
  typeName        String   @map("type_name")
  sidoCode        String   @map("sido_code")
  sidoName        String   @map("sido_name")
  sigunguCode     String   @map("sigungu_code")
  sigunguName     String   @map("sigungu_name")
  eupmyeondong    String?  @map("eupmyeondong")
  postalCode      String?  @map("postal_code")
  address         String?  @map("address")
  phone           String?  @map("phone")
  homepage        String?  @map("homepage")
  totalDoctors    Int?     @map("total_doctors")
  openedAt        String?  @map("opened_at")
  coordinateX     String?  @map("coordinate_x")
  coordinateY     String?  @map("coordinate_y")
  mdeptGdrCnt     Int?     @map("mdept_gdr_cnt")
  mdeptIntnCnt    Int?     @map("mdept_intn_cnt")
  mdeptResdntCnt  Int?     @map("mdept_resdnt_cnt")
  mdeptSdrCnt     Int?     @map("mdept_sdr_cnt")
  detyGdrCnt      Int?     @map("dety_gdr_cnt")
  detyIntnCnt     Int?     @map("dety_intn_cnt")
  detyResdntCnt   Int?     @map("dety_resdnt_cnt")
  detySdrCnt      Int?     @map("dety_sdr_cnt")
  cmdcGdrCnt      Int?     @map("cmdc_gdr_cnt")
  cmdcIntnCnt     Int?     @map("cmdc_intn_cnt")
  cmdcResdntCnt   Int?     @map("cmdc_resdnt_cnt")
  cmdcSdrCnt      Int?     @map("cmdc_sdr_cnt")
  midwifeCnt      Int?     @map("midwife_cnt")
  createdAt       DateTime @default(now()) @map("created_at")
  hospital        Hospital?

  @@map("hira_hospitals")
  @@schema("public")
}

model Hospital {
  id                Int      @id @default(autoincrement())
  hospitalCode      String   @unique @map("hospital_code")
  hiraId            String?  @unique @map("hira_id")
  hiraHospitalName  String   @map("hira_hospital_name")
  hospitalName      String   @map("hospital_name")
  type              String   @map("type")
  sidoCode       String?  @map("sido_code")
  sidoName       String?  @map("sido_name")
  sigunguCode    String?  @map("sigungu_code")
  sigunguName    String?  @map("sigungu_name")
  eupmyeondong   String?  @map("eupmyeondong")
  postalCode     String?  @map("postal_code")
  address        String?  @map("address")
  coordinateX    String?  @map("coordinate_x")
  coordinateY    String?  @map("coordinate_y")
  status         String   @map("status")
  introType      String?  @map("intro_type")
  introBeds      Int?     @map("intro_beds")
  contractDate   DateTime? @map("contract_date")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  hiraHospital        HiraHospital? @relation(fields: [hiraId], references: [hiraId])
  daewoongAssignments DaewoongHospitalAssignment[]
  projects            Project[]
  meta                HospitalMeta?
  hospitalDevices     HospitalDevice[]
  siteVisits          SiteVisit[]
  introTypes          HospitalIntroType[]
  installPlans        InstallPlan[]
  maintenances        Maintenance[]
  consultationQueues  ConsultationQueue[]
  tasks               Task[]
  etcTaskHospitals    EtcTaskHospital[]
  inventoryTransactions InventoryTransaction[]
  inventoryUnits        InventoryUnit[]
  aiChatSessions        AiChatSession[]

  @@map("hospitals")
  @@schema("public")
}

model HospitalIntroType {
  id           Int        @id @default(autoincrement())
  hospitalId   Int        @map("hospital_id")
  statusCodeId Int        @map("status_code_id")
  hospital     Hospital   @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  statusCode   StatusCode @relation(fields: [statusCodeId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, statusCodeId])
  @@map("hospital_intro_types")
  @@schema("public")
}

model DaewoongHospitalAssignment {
  id             String   @id @default(uuid())
  hospitalCode   String   @map("hospital_code")
  assignedUserId String   @map("assigned_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  hospital       Hospital @relation(fields: [hospitalCode], references: [hospitalCode])
  assignedUser   User     @relation(fields: [assignedUserId], references: [id])

  @@unique([hospitalCode, assignedUserId])
  @@map("daewoong_hospital_assignments")
  @@schema("public")
}

model StatusCode {
  id        Int      @id @default(autoincrement())
  name      String   @map("name")
  value     String?  @map("value")
  order     Int      @default(0) @map("order")
  color     String?  @map("color")
  category  String   @default("HOSPITAL") @map("category")
  createdAt DateTime @default(now()) @map("created_at")
  siteVisits                    SiteVisit[]
  hospitalIntroTypes            HospitalIntroType[]
  introTypeProjects             Project[]              @relation("ProjectIntroType")
  consultationTypeQueues        ConsultationQueue[]    @relation("ConsultationTypeQueue")
  documentTypeQueues            ConsultationQueue[]    @relation("DocumentTypeQueue")
  maintenanceTypes              Maintenance[]          @relation("MaintenanceType")
  maintenanceStatuses           Maintenance[]          @relation("MaintenanceStatus")
  etcTaskStatuses               EtcTask[]              @relation("EtcTaskStatus")
  manufacturerItems             InventoryItem[]        @relation("ItemManufacturer")
  reasonTransactions            InventoryTransaction[] @relation("TxReason")

  @@unique([name, category])
  @@map("status_codes")
  @@schema("public")
}

model ConsultationQueue {
  id                  Int         @id @default(autoincrement())
  hospitalCode        String?     @map("hospital_code")
  consultationTypeId  Int?        @map("consultation_type_id")
  documentTypeId      Int?        @map("document_type_id")
  conclusion          String?
  chatHistory         Json        @default("[]") @map("chat_history")
  aiSummary           String?     @map("ai_summary")
  status              String      @default("PENDING")
  consultedById       String      @map("consulted_by_id")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @default(now()) @map("updated_at")

  hospital            Hospital?   @relation(fields: [hospitalCode], references: [hospitalCode])
  consultationType    StatusCode? @relation("ConsultationTypeQueue", fields: [consultationTypeId], references: [id])
  documentType        StatusCode? @relation("DocumentTypeQueue", fields: [documentTypeId], references: [id])
  consultedBy         User        @relation(fields: [consultedById], references: [id])

  @@map("consultation_queue")
  @@schema("public")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  VIEWER

  @@schema("public")
}

model Organization {
  id          Int          @id @default(autoincrement())
  name        String
  code        String       @unique
  isActive    Boolean      @default(true) @map("is_active")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  users       User[]
  departments Department[]

  @@map("organizations")
  @@schema("public")
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  password       String
  name           String
  phone          String
  role           Role          @default(USER)
  isActive       Boolean       @default(true) @map("is_active")
  vehicleReservationBlocked Boolean @default(false) @map("vehicle_reservation_blocked")
  organizationId Int?          @map("organization_id")
  departmentId   Int?          @map("department_id")
  slackUserId    String?       @map("slack_user_id") @db.VarChar(20) // Slack DM 매핑 캐시 (Phase 4)
  slackNotifyEnabled Boolean   @default(true) @map("slack_notify_enabled") // 계정별 Slack 발송 유무(false=미발송)
  createdAt      DateTime      @default(now()) @map("created_at")
  lastLoginAt    DateTime?     @map("last_login_at")
  organization            Organization?                @relation(fields: [organizationId], references: [id])
  department              Department?                  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  fieldEngineers          FieldEngineer[]
  daewoongSiteVisits      SiteVisit[]                  @relation("SiteVisitDaewoongUser")
  hospitalAssignments     DaewoongHospitalAssignment[]
  projectAssignees        ProjectAssignee[]
  installPlanAssignees    InstallPlanAssignee[]
  siteVisitAssignees      SiteVisitAssignee[]
  maintenanceAssignees    MaintenanceAssignee[]
  maintenanceLogs         MaintenanceLog[]             @relation("MaintenanceLogAuthor")
  etcTaskAssignees        EtcTaskAssignee[]
  consultationQueues      ConsultationQueue[]
  wikiPagesAuthored       WikiPage[]                   @relation("WikiPageAuthor")
  wikiPagesEdited         WikiPage[]                   @relation("WikiPageLastEditor")
  wikiAttachmentsUploaded WikiAttachment[]             @relation("WikiAttachmentUploader")
  wikiPageRefsCreated     WikiPageReference[]          @relation("WikiPageRefCreator")
  wikiFavorites           WikiFavorite[]               @relation("WikiFavoriteUser")
  wikiViewLogs            WikiViewLog[]                @relation("WikiViewLogUser")
  wikiVersionsSaved       WikiVersion[]                @relation("WikiVersionSaver")
  wikiCommentsAuthored    WikiComment[]                @relation("WikiCommentAuthor")
  vehicleReservations     VehicleReservation[]         @relation("VehicleReservationUser")
  vehicleLogsDriven       VehicleLog[]                 @relation("VehicleLogDriver")
  vehicleLogsCreated      VehicleLog[]                 @relation("VehicleLogCreator")
  inventoryManager        InventoryManager?
  inventoryTxActed        InventoryTransaction[]       @relation("InventoryTxActor")
  inventoryTxCanceled     InventoryTransaction[]       @relation("InventoryTxCanceler")
  aiChatSessions          AiChatSession[]
  gatewayPlanJobs         GatewayPlanJob[]             @relation("GatewayPlanJobCreator")

  @@map("users")
  @@schema("public")
}

model Department {
  id             Int          @id @default(autoincrement())
  name           String       @db.VarChar(100)
  organizationId Int          @map("organization_id")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  users          User[]

  @@map("departments")
  @@schema("public")
}

model FieldEngineer {
  id        Int      @id @default(autoincrement())
  userId    String   @map("user_id")
  workType  String   @default("PROJECT") @map("work_type")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, workType])
  @@index([workType])
  @@map("field_engineers")
  @@schema("public")
}

model DeviceInfo {
  id          Int      @id @default(autoincrement())
  deviceModel String   @unique @map("device_model")
  deviceName  String   @map("device_name")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  devices         ProjectDevice[]
  hospitalDevices HospitalDevice[]
  inventoryItems  InventoryItem[]

  @@map("device_info")
  @@schema("public")
}

model Contractor {
  id             Int       @id @default(autoincrement())
  code           String    @unique @map("code")
  name           String    @map("name")
  bizRegNumber   String?   @map("biz_reg_number")
  managerName    String?   @map("manager_name")
  managerPhone   String?   @map("manager_phone")
  managerEmail   String?   @map("manager_email")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  projects       Project[]

  @@map("constructors")
  @@schema("public")
}

model BuildStatus {
  id        Int       @id @default(autoincrement())
  label     String    @map("label")
  color     String?   @map("color")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  projects  Project[]

  @@map("build_statuses")
  @@schema("public")
}

model Project {
  id                  Int          @id @default(autoincrement())
  projectCode         String       @unique @map("project_code")
  projectName         String       @map("project_name")
  hospitalCode        String       @map("hospital_code")
  orderNumber         Int          @map("order_number")
  contractDate        DateTime?    @map("contract_date")
  contractType        String?      @map("contract_type")
  wardCount           Int?         @map("ward_count")
  bedCount            Int?         @map("bed_count")
  gatewayCount        Int?         @map("gateway_count")
  hasSurvey           Boolean      @default(false) @map("has_survey")
  hasOrder            Boolean      @default(false) @map("has_order")
  builderNameManual   String?      @map("builder_name_manual")
  constructorId       Int?         @map("constructor_id")
  startDate           DateTime?    @map("start_date")
  endDateExpected     DateTime?    @map("end_date_expected")
  buildStatusId       Int?         @map("build_status_id")
  statusChangedAt     DateTime?    @default(now()) @map("status_changed_at") // 현재 공사상태 진입 시각 (단계 체류 지연 감지)
  introTypeId         Int?         @map("intro_type_id")
  issueNote           String?      @db.Text @map("issue_note")
  remark              String?      @map("remark")
  driveFolderId       String?      @map("drive_folder_id")
  calendarEventId     String?      @map("calendar_event_id")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")
  hospital            Hospital     @relation(fields: [hospitalCode], references: [hospitalCode])
  contractor          Contractor?  @relation(fields: [constructorId], references: [id])
  buildStatus         BuildStatus? @relation(fields: [buildStatusId], references: [id])
  introType           StatusCode?  @relation("ProjectIntroType", fields: [introTypeId], references: [id])
  devices             ProjectDevice[]
  files               ProjectFile[]
  assignees           ProjectAssignee[]

  @@map("projects")
  @@schema("public")
}

model ProjectDevice {
  id           Int        @id @default(autoincrement())
  projectId    Int        @map("project_id")
  deviceInfoId Int        @map("device_info_id")
  quantity     Int        @default(0) @map("quantity")
  createdAt    DateTime   @default(now()) @map("created_at")
  project      Project    @relation(fields: [projectId], references: [id])
  deviceInfo   DeviceInfo @relation(fields: [deviceInfoId], references: [id])

  @@unique([projectId, deviceInfoId])
  @@map("project_devices")
  @@schema("public")
}

model HospitalDevice {
  id           Int        @id @default(autoincrement())
  hospitalCode String     @map("hospital_code")
  hospital     Hospital   @relation(fields: [hospitalCode], references: [hospitalCode])
  deviceInfoId Int        @map("device_info_id")
  deviceInfo   DeviceInfo @relation(fields: [deviceInfoId], references: [id])
  quantity     Int        @default(0) @map("quantity")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([hospitalCode, deviceInfoId])
  @@map("hospital_devices")
  @@schema("public")
}

model HospitalMeta {
  id                     Int      @id @default(autoincrement())
  hospitalCode           String   @unique @map("hospital_code")
  hospital               Hospital @relation(fields: [hospitalCode], references: [hospitalCode])
  driveProjectFolderId   String?  @map("drive_project_folder_id")
  driveStatusFileId      String?  @map("drive_status_file_id")
  driveInstallPlanFileId String?  @map("drive_install_plan_file_id")
  remoteAccessUrl        String?  @map("remote_access_url")
  remoteControlUrl       String?  @map("remote_control_url")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("hospital_meta")
  @@schema("public")
}

model ProjectFile {
  id           Int      @id @default(autoincrement())
  projectId    Int      @map("project_id")
  fileCategory String   @map("file_category")
  fileName     String   @map("file_name")
  driveFileId  String   @map("drive_file_id")
  driveUrl     String   @map("drive_url")
  s3Key        String?  @map("s3_key")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  project      Project  @relation(fields: [projectId], references: [id])

  @@map("project_files")
  @@schema("public")
}

model SiteVisit {
  id              Int            @id @default(autoincrement())
  siteVisitCode   String?        @unique @map("site_visit_code") @db.VarChar(50)
  hospitalCode    String         @map("hospital_code")
  daewoongUserId  String?        @map("daewoong_user_id")
  requestDate     DateTime?      @map("request_date")
  visitDate       DateTime?      @map("visit_date")
  replyDate       DateTime?      @map("reply_date")
  statusId        Int?           @map("status_id")
  statusChangedAt DateTime?      @default(now()) @map("status_changed_at") // 현재 상태 진입 시각 (단계 체류 지연 감지)
  installPlanUrl    String?  @map("install_plan_url")
  installPlanFileId String?  @map("install_plan_file_id")
  floorPlanUrl      String?  @map("floor_plan_url")
  floorPlanFileId   String?  @map("floor_plan_file_id")
  installPlanS3Key  String?  @map("install_plan_s3_key")
  floorPlanS3Key    String?  @map("floor_plan_s3_key")
  notes           String?        @db.Text @map("notes")
  calendarEventId String?        @map("calendar_event_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  hospital      Hospital         @relation(fields: [hospitalCode], references: [hospitalCode])
  daewoongUser  User?            @relation("SiteVisitDaewoongUser", fields: [daewoongUserId], references: [id])
  status        StatusCode?      @relation(fields: [statusId], references: [id])
  files         SiteVisitFile[]
  assignees     SiteVisitAssignee[]
  queue         SiteVisitQueue?

  @@map("site_visits")
  @@schema("public")
}

model SiteVisitFile {
  id           Int       @id @default(autoincrement())
  siteVisitId  Int       @map("site_visit_id")
  fileCategory String    @map("file_category")
  fileName     String    @map("file_name")
  s3Key        String    @map("s3_key")
  uploadedAt   DateTime  @default(now()) @map("uploaded_at")
  siteVisit    SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)

  @@map("site_visit_files")
  @@schema("public")
}

model InstallPlan {
  id           Int       @id @default(autoincrement())
  planCode     String?   @unique @map("plan_code")
  hospitalCode String?   @map("hospital_code")
  requestDate  DateTime? @map("request_date") @db.Date
  writeStatus  String    @default("-") @map("write_status")
  replyStatus  String    @default("-") @map("reply_status")
  replyDate    DateTime? @map("reply_date") @db.Date
  note         String?

  hospital  Hospital?         @relation(fields: [hospitalCode], references: [hospitalCode])
  files     InstallPlanFile[]
  assignees InstallPlanAssignee[]
  queueItem InstallPlanQueue?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("install_plans")
  @@schema("public")
}

model InstallPlanFile {
  id            Int         @id @default(autoincrement())
  installPlanId Int         @map("install_plan_id")
  fileCategory  String      @map("file_category")
  fileName      String      @map("file_name")
  s3Key         String      @map("s3_key")
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  installPlan   InstallPlan @relation(fields: [installPlanId], references: [id], onDelete: Cascade)

  @@map("install_plan_files")
  @@schema("public")
}

model HiraSyncJob {
  id         Int           @id @default(autoincrement())
  startedAt  DateTime      @default(now()) @map("started_at")
  endedAt    DateTime?     @map("ended_at")
  status     String        @default("running") @map("status")
  totalCount Int           @default(0) @map("total_count")
  logs       HiraSyncLog[]

  @@map("hira_sync_jobs")
  @@schema("public")
}

model ProjectAssignee {
  id          Int      @id @default(autoincrement())
  projectCode String   @map("project_code")
  userId      String   @map("user_id")
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectCode], references: [projectCode], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectCode, userId])
  @@map("project_assignees")
  @@schema("public")
}

model InstallPlanAssignee {
  id            Int         @id @default(autoincrement())
  installPlanId Int         @map("install_plan_id")
  userId        String      @map("user_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  installPlan   InstallPlan @relation(fields: [installPlanId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([installPlanId, userId])
  @@map("install_plan_assignees")
  @@schema("public")
}

model SiteVisitAssignee {
  id          Int       @id @default(autoincrement())
  siteVisitId Int       @map("site_visit_id")
  userId      String    @map("user_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  siteVisit   SiteVisit @relation(fields: [siteVisitId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([siteVisitId, userId])
  @@map("site_visit_assignees")
  @@schema("public")
}

model HiraSyncLog {
  id        Int         @id @default(autoincrement())
  jobId     Int         @map("job_id")
  job       HiraSyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  type      String      @map("type")
  message   String      @map("message")
  stats     Json?       @map("stats")
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("hira_sync_logs")
  @@schema("public")
}

model InstallPlanQueue {
  id              Int          @id @default(autoincrement())
  gmailMessageId  String       @unique @map("gmail_message_id")
  receivedAt      DateTime     @map("received_at")
  hospitalNameRaw String       @map("hospital_name_raw")
  requestDate     DateTime?    @map("request_date")
  managerName     String       @map("manager_name")
  managerPhone    String       @map("manager_phone")
  managerEmail    String       @map("manager_email")
  totalBeds       String       @map("total_beds")
  address         String       @default("") @db.Text
  model           String
  rawBody         String       @map("raw_body") @db.Text
  fileUrl         String       @default("") @map("file_url") @db.Text
  status          String       @default("pending")
  installPlanId   Int?         @unique @map("install_plan_id")
  installPlan     InstallPlan? @relation(fields: [installPlanId], references: [id])
  createdAt       DateTime     @default(now()) @map("created_at")

  @@map("install_plan_queue")
  @@schema("public")
}

model SiteVisitQueue {
  id              Int        @id @default(autoincrement())
  gmailMessageId  String     @unique @map("gmail_message_id")
  receivedAt      DateTime   @map("received_at")
  hospitalNameRaw String     @map("hospital_name_raw")
  requestDate     DateTime?  @map("request_date")
  managerName     String     @map("manager_name")
  managerPhone    String     @map("manager_phone")
  managerEmail    String     @map("manager_email")
  totalBeds       String     @map("total_beds")
  address         String     @default("") @db.Text
  model           String
  rawBody         String     @map("raw_body") @db.Text
  fileUrl         String     @default("") @map("file_url") @db.Text
  status          String     @default("pending")
  siteVisitId     Int?       @unique @map("site_visit_id")
  siteVisit       SiteVisit? @relation(fields: [siteVisitId], references: [id])
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("site_visit_queue")
  @@schema("public")
}

model AppSetting {
  key   String @id
  value String @default("")

  @@map("app_settings")
  @@schema("public")
}

// Slack 알림 발송 이력 (function_notification.md Phase 1)
// 이벤트/지연 알림 발송 기록 + 중복 발송 방지(dedup) 근거 테이블
model NotificationLog {
  id         Int      @id @default(autoincrement())
  eventType  String   @map("event_type") @db.VarChar(30) // task_created | task_completed | delayed
  taskType   String?  @map("task_type") @db.VarChar(20)  // PROJECT | SITE_VISIT | INSTALL_PLAN | MAINTENANCE | ETC
  refCode    String?  @map("ref_code") @db.VarChar(50)   // 원본 업무 코드
  targetType String   @map("target_type") @db.VarChar(10) // channel | dm
  targetId   String   @map("target_id") @db.VarChar(50)   // 채널 ID 또는 Slack user ID
  status     String   @db.VarChar(10)                     // sent | failed | skipped
  error      String?
  payload    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventType, refCode, targetId, createdAt])
  @@index([createdAt])
  @@map("notification_logs")
  @@schema("public")
}

model NavMenuItem {
  id              Int      @id @default(autoincrement())
  menuKey         String   @unique @map("menu_key") @db.VarChar(100)
  label           String   @map("label") @db.VarChar(200)
  href            String   @map("href") @db.VarChar(200)
  iconKey         String?  @map("icon_key") @db.VarChar(50)
  parentKey       String?  @map("parent_key") @db.VarChar(100)
  groupLabel      String?  @map("group_label") @db.VarChar(50) // 설정 하위 메뉴 기능별 그룹 (네비 그룹 헤더)
  allowedRoles    String[] @default([]) @map("allowed_roles")
  allowedOrgCodes String[] @default([]) @map("allowed_org_codes")
  isActive        Boolean  @default(true) @map("is_active")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("nav_menu_items")
  @@schema("public")
}

// ─── 자재관리(WMS) Phase 1 ─── (function_wms.md §4)

// 위치(창고) — 인벤토리에 귀속 (인벤토리별 독립 추가/삭제, 위치명은 인벤토리 내 UNIQUE)
model Warehouse {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(50)
  inventoryId Int      @map("inventory_id")
  memo        String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  inventory   Inventory @relation(fields: [inventoryId], references: [id])
  stocks      InventoryStock[]
  txFrom      InventoryTransaction[] @relation("TxFromWarehouse")
  txTo        InventoryTransaction[] @relation("TxToWarehouse")
  units       InventoryUnit[]

  @@unique([inventoryId, name])
  @@map("warehouses")
  @@schema("public")
}

model InventoryCategory {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(50)
  parentId  Int?     @map("parent_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  parent    InventoryCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  InventoryCategory[] @relation("CategoryTree")
  items     InventoryItem[]

  // UNIQUE (COALESCE(parent_id,0), name)는 SQL 전용 (Prisma 미표현 — 마이그레이션 참조)
  @@index([parentId])
  @@map("inventory_categories")
  @@schema("public")
}

// 품목 마스터 — 인벤토리에 귀속. 같은 물건(예: MC200M-T)도 인벤토리마다 별도 품목·별도 코드로 관리
model InventoryItem {
  id              Int         @id @default(autoincrement())
  itemCode        String      @unique @map("item_code") @db.VarChar(20)
  name            String      @db.VarChar(100)
  modelName       String?     @map("model_name") @db.VarChar(100) // 제조사 모델명 (규격과 별개)
  inventoryId     Int         @map("inventory_id") // 소속 인벤토리 (변경 불가)
  categoryId      Int?        @map("category_id")
  spec            String?     @db.VarChar(200)
  unit            String      @default("EA") @db.VarChar(20)
  isSerialManaged Boolean     @default(false) @map("is_serial_managed")
  isLotManaged    Boolean     @default(false) @map("is_lot_managed") // LOT 추적 대상 — 시리얼 품목: 신규 입고 시 개체별 LOT 필수 / 비시리얼 품목: 전표 단위 LOT 선택 기록
  tags            String[]    @default([]) // deprecated (2026-07-20) — 태그는 개체(InventoryUnit.tags) 단위로 이관, 백업 보존
  deviceInfoId    Int?        @map("device_info_id")
  manufacturerId  Int?        @map("manufacturer_id")
  refPrice        Int?        @map("ref_price")
  memo            String?
  isActive        Boolean     @default(true) @map("is_active")
  sortOrder       Int         @default(0) @map("sort_order")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  inventory       Inventory   @relation("InventoryItems", fields: [inventoryId], references: [id])
  category        InventoryCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  deviceInfo      DeviceInfo? @relation(fields: [deviceInfoId], references: [id], onDelete: SetNull)
  manufacturer    StatusCode? @relation("ItemManufacturer", fields: [manufacturerId], references: [id], onDelete: SetNull)
  stocks          InventoryStock[]
  transactions    InventoryTransaction[]
  units           InventoryUnit[]
  components      InventoryItemComponent[] @relation("ComponentParent") // 이 품목이 주자재일 때의 부자재 구성
  usedIn          InventoryItemComponent[] @relation("ComponentChild")  // 이 품목이 부자재로 소속된 주자재

  @@index([categoryId])
  @@index([inventoryId])
  @@map("inventory_items")
  @@schema("public")
}

// 인벤토리 마스터 — 대웅제약재고 / 평가용재고 / 판매용재고 (품목·위치·재고·전표 전부 인벤토리별 완전 독립)
model Inventory {
  id               Int      @id @default(autoincrement())
  name             String   @unique @db.VarChar(50)
  linkHospital     Boolean  @default(false) @map("link_hospital") // true면 출고 시 병원 연결 허용 (대웅제약재고)
  memo             String?
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  items            InventoryItem[] @relation("InventoryItems")
  warehouses       Warehouse[]
  stocks           InventoryStock[]
  txFrom           InventoryTransaction[] @relation("TxInventory")
  txTo             InventoryTransaction[] @relation("TxToInventory")
  units            InventoryUnit[]

  @@map("inventories")
  @@schema("public")
}

// 주자재-부자재 매핑 (1단계 깊이 — 부자재는 다시 주자재가 될 수 없음, API 검증)
model InventoryItemComponent {
  parentItemId Int      @map("parent_item_id")
  childItemId  Int      @map("child_item_id")
  quantity     Int      @default(1) // 주자재 1개당 부자재 구성 수량
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  parent       InventoryItem @relation("ComponentParent", fields: [parentItemId], references: [id], onDelete: Cascade)
  child        InventoryItem @relation("ComponentChild", fields: [childItemId], references: [id], onDelete: Cascade)

  @@id([parentItemId, childItemId])
  @@index([childItemId])
  @@map("inventory_item_components")
  @@schema("public")
}

model InventoryManager {
  id        Int      @id @default(autoincrement())
  userId    String   @unique @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("inventory_managers")
  @@schema("public")
}

model InventoryStock {
  itemId      Int      @map("item_id")
  warehouseId Int      @map("warehouse_id")
  inventoryId Int      @map("inventory_id")
  lotNo       String   @default("") @map("lot_no") @db.VarChar(100) // LOT 재고 차원 (2026-07-20) — ''=LOT 없음. 비시리얼 LOT 품목만 실값 사용
  quantity    Int      @default(0)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  inventory   Inventory     @relation(fields: [inventoryId], references: [id])

  @@id([itemId, warehouseId, inventoryId, lotNo])
  @@map("inventory_stocks")
  @@schema("public")
}

model InventoryTransaction {
  id            Int       @id @default(autoincrement())
  txCode        String    @unique @map("tx_code") @db.VarChar(20)
  txType        String    @map("tx_type") @db.VarChar(10) // IN | OUT | MOVE (TRANSFER는 폐지 — 과거 전표만 존재)
  reasonId      Int?      @map("reason_id") // IN/OUT 유형 (StatusCode STOCK_IN_TYPE/STOCK_OUT_TYPE), MOVE는 NULL
  itemId        Int       @map("item_id")
  warehouseId   Int       @map("warehouse_id")
  toWarehouseId Int?      @map("to_warehouse_id") // MOVE 도착 위치
  inventoryId   Int       @map("inventory_id") // = item.inventoryId (비정규화 — 서버에서 강제)
  toInventoryId Int?      @map("to_inventory_id") // deprecated — 과거 TRANSFER 전표 표시용
  quantity      Int
  txDate        DateTime  @default(now()) @map("tx_date") @db.Date // 입출고일 — 업무 기준일 (소급 등록 지원, 2026-07-20)
  transferDate  DateTime? @map("transfer_date") @db.Date // deprecated — 과거 TRANSFER 이관일자
  transferPrice Int?      @map("transfer_price") // deprecated — 과거 TRANSFER 이관 단가
  destination   String?   @db.VarChar(100) // OUT 출고처 (자유 텍스트 — 유관부서·거래처 등)
  requester     String?   @db.VarChar(100) // 요청자 (자유 텍스트 — OUT 필수, IN 선택)
  lotNo         String?   @map("lot_no") @db.VarChar(100) // 전표 단위 LOT — 비시리얼 LOT 품목(선택) / 시리얼 품목 단건 입고 시 표기용
  hospitalCode  String?   @map("hospital_code")
  workType      String?   @map("work_type") @db.VarChar(20)
  refCode       String?   @map("ref_code") @db.VarChar(50)
  parentTxId    Int?      @map("parent_tx_id") // 세트출고 자식 전표 → 주자재 전표
  note          String?
  actorId       String    @map("actor_id")
  canceledAt    DateTime? @map("canceled_at")
  canceledById  String?   @map("canceled_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  item          InventoryItem @relation(fields: [itemId], references: [id])
  warehouse     Warehouse     @relation("TxFromWarehouse", fields: [warehouseId], references: [id])
  toWarehouse   Warehouse?    @relation("TxToWarehouse", fields: [toWarehouseId], references: [id])
  inventory     Inventory     @relation("TxInventory", fields: [inventoryId], references: [id])
  toInventory   Inventory?    @relation("TxToInventory", fields: [toInventoryId], references: [id])
  reasonCode    StatusCode?   @relation("TxReason", fields: [reasonId], references: [id])
  hospital      Hospital?     @relation(fields: [hospitalCode], references: [hospitalCode])
  actor         User          @relation("InventoryTxActor", fields: [actorId], references: [id])
  canceledBy    User?         @relation("InventoryTxCanceler", fields: [canceledById], references: [id])
  parentTx      InventoryTransaction?  @relation("TxSetComponents", fields: [parentTxId], references: [id])
  childTxs      InventoryTransaction[] @relation("TxSetComponents")
  units         InventoryTransactionUnit[]

  @@index([itemId, createdAt(sort: Desc)])
  @@index([hospitalCode])
  @@index([workType, refCode])
  @@index([createdAt(sort: Desc)])
  @@index([inventoryId, createdAt(sort: Desc)])
  @@index([parentTxId])
  @@map("inventory_transactions")
  @@schema("public")
}

model InventoryUnit {
  id           Int      @id @default(autoincrement())
  itemId       Int      @map("item_id")
  serialNo     String   @map("serial_no") @db.VarChar(100)
  lotNo        String?  @map("lot_no") @db.VarChar(100) // LOT 관리 품목의 로트 번호 (신규 입고 시 기록)
  status       String   @default("IN_STOCK") @db.VarChar(10)
  warehouseId  Int?     @map("warehouse_id")
  inventoryId  Int      @map("inventory_id")
  hospitalCode String?  @map("hospital_code")
  memo         String?
  tags         String[] @default([]) // 개체(단품) 자유 태그 — 예: DEMO, 각인 (2026-07-20)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  item         InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?    @relation(fields: [warehouseId], references: [id])
  inventory    Inventory     @relation(fields: [inventoryId], references: [id])
  hospital     Hospital?     @relation(fields: [hospitalCode], references: [hospitalCode])
  transactions InventoryTransactionUnit[]

  @@unique([itemId, serialNo])
  @@index([itemId, status])
  @@index([hospitalCode])
  @@index([inventoryId])
  @@map("inventory_units")
  @@schema("public")
}

model InventoryTransactionUnit {
  transactionId Int @map("transaction_id")
  unitId        Int @map("unit_id")
  transaction   InventoryTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  unit          InventoryUnit        @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@id([transactionId, unitId])
  @@index([unitId])
  @@map("inventory_transaction_units")
  @@schema("public")
}

model Task {
  id           Int       @id @default(autoincrement())
  taskCode     String    @unique @map("task_code") @db.VarChar(20)
  taskType     String    @map("task_type") @db.VarChar(20)
  refCode      String    @map("ref_code") @db.VarChar(50)
  hospitalCode String?   @map("hospital_code") @db.VarChar(50)
  title        String?
  isCompleted  Boolean   @default(false) @map("is_completed")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  hospital Hospital? @relation(fields: [hospitalCode], references: [hospitalCode])

  @@index([taskType])
  @@index([refCode])
  @@index([hospitalCode])
  @@map("tasks")
  @@schema("public")
}

model Maintenance {
  id                Int       @id @default(autoincrement())
  maintenanceCode   String?   @unique @map("maintenance_code")
  hospitalCode      String    @map("hospital_code")
  typeId            Int?      @map("type_id")
  statusId          Int?      @map("status_id")
  statusChangedAt   DateTime? @default(now()) @map("status_changed_at") // 현재 상태 진입 시각 (단계 체류 지연 감지)
  priority          String    @default("보통") @map("priority")
  title             String    @map("title")
  reporterName      String?   @map("reporter_name")
  isRemote          Boolean   @default(false) @map("is_remote")
  reportedAt        DateTime? @map("reported_at") @db.Date
  visitDate         DateTime? @map("visit_date") @db.Date // deprecated: 방문일정은 visits(MaintenanceVisit)로 이전
  resolvedAt        DateTime? @map("resolved_at") @db.Date
  symptoms          String?   @db.Text @map("symptoms")
  cause             String?   @db.Text @map("cause") // deprecated: resolution(조치 요약)에 병합됨 — 백업용 보존, 앱에서 미사용
  resolution        String?   @db.Text @map("resolution") // 조치 요약 (원인 포함, 종결 시 작성)
  notes             String?   @db.Text @map("notes") // deprecated: maintenance_logs(처리 기록)로 이관됨 — 백업용 보존, 앱에서 미사용
  calendarEventId   String?   @map("calendar_event_id") // deprecated: 캘린더 이벤트ID는 방문 항목별(MaintenanceVisit.calendarEventId)로 이전
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  hospital   Hospital    @relation(fields: [hospitalCode], references: [hospitalCode])
  type       StatusCode? @relation("MaintenanceType", fields: [typeId], references: [id])
  status     StatusCode? @relation("MaintenanceStatus", fields: [statusId], references: [id])
  assignees  MaintenanceAssignee[]
  files      MaintenanceFile[]
  visits     MaintenanceVisit[]
  logs       MaintenanceLog[]

  @@map("maintenances")
  @@schema("public")
}

// 처리 기록 — 유지보수 진행 경과 타임라인 (구 비고 필드 대체, 엔트리별 작성자·시각 자동 기록)
model MaintenanceLog {
  id            Int         @id @default(autoincrement())
  maintenanceId Int         @map("maintenance_id")
  authorId      String?     @map("author_id") // NULL = 구 비고 필드 이관분 (작성자 미상)
  content       String      @db.Text // Tiptap HTML
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  author        User?       @relation("MaintenanceLogAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([maintenanceId, createdAt(sort: Desc)])
  @@map("maintenance_logs")
  @@schema("public")
}

model MaintenanceVisit {
  id              Int         @id @default(autoincrement())
  maintenanceId   Int         @map("maintenance_id")
  startDate       DateTime    @map("start_date") @db.Date
  endDate         DateTime    @map("end_date") @db.Date
  calendarEventId String?     @map("calendar_event_id")
  sortOrder       Int         @default(0) @map("sort_order")
  createdAt       DateTime    @default(now()) @map("created_at")
  maintenance     Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@index([maintenanceId])
  @@map("maintenance_visits")
  @@schema("public")
}

model MaintenanceAssignee {
  id            Int         @id @default(autoincrement())
  maintenanceId Int         @map("maintenance_id")
  userId        String      @map("user_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([maintenanceId, userId])
  @@map("maintenance_assignees")
  @@schema("public")
}

model EtcTask {
  id          Int       @id @default(autoincrement())
  etcTaskCode String?   @unique @map("etc_task_code")
  title       String    @map("title")
  statusId    Int?      @map("status_id")
  statusChangedAt DateTime? @default(now()) @map("status_changed_at") // 현재 상태 진입 시각 (단계 체류 지연 감지)
  priority    String    @default("보통") @map("priority")
  reportedAt  DateTime? @map("reported_at") @db.Date
  resolvedAt  DateTime? @map("resolved_at") @db.Date
  note        String?   @db.Text @map("note")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  status    StatusCode?       @relation("EtcTaskStatus", fields: [statusId], references: [id])
  assignees EtcTaskAssignee[]
  hospitals EtcTaskHospital[]
  visits    EtcTaskVisit[]
  files     EtcTaskFile[]

  @@map("etc_tasks")
  @@schema("public")
}

model EtcTaskAssignee {
  id        Int      @id @default(autoincrement())
  etcTaskId Int      @map("etc_task_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  etcTask   EtcTask  @relation(fields: [etcTaskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([etcTaskId, userId])
  @@map("etc_task_assignees")
  @@schema("public")
}

model EtcTaskHospital {
  id           Int      @id @default(autoincrement())
  etcTaskId    Int      @map("etc_task_id")
  hospitalCode String   @map("hospital_code")
  createdAt    DateTime @default(now()) @map("created_at")
  etcTask      EtcTask  @relation(fields: [etcTaskId], references: [id], onDelete: Cascade)
  hospital     Hospital @relation(fields: [hospitalCode], references: [hospitalCode])

  @@unique([etcTaskId, hospitalCode])
  @@index([hospitalCode])
  @@map("etc_task_hospitals")
  @@schema("public")
}

model EtcTaskVisit {
  id              Int      @id @default(autoincrement())
  etcTaskId       Int      @map("etc_task_id")
  startDate       DateTime @map("start_date") @db.Date
  endDate         DateTime @map("end_date") @db.Date
  calendarEventId String?  @map("calendar_event_id")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  etcTask         EtcTask  @relation(fields: [etcTaskId], references: [id], onDelete: Cascade)

  @@index([etcTaskId])
  @@map("etc_task_visits")
  @@schema("public")
}

model EtcTaskFile {
  id           Int      @id @default(autoincrement())
  etcTaskId    Int      @map("etc_task_id")
  fileCategory String   @map("file_category")
  fileName     String   @map("file_name")
  s3Key        String   @map("s3_key")
  uploadedAt   DateTime @default(now()) @map("uploaded_at")
  etcTask      EtcTask  @relation(fields: [etcTaskId], references: [id], onDelete: Cascade)

  @@map("etc_task_files")
  @@schema("public")
}

model MaintenanceFile {
  id            Int         @id @default(autoincrement())
  maintenanceId Int         @map("maintenance_id")
  fileCategory  String      @map("file_category")
  fileName      String      @map("file_name")
  s3Key         String      @map("s3_key")
  uploadedAt    DateTime    @default(now()) @map("uploaded_at")
  maintenance   Maintenance @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@map("maintenance_files")
  @@schema("public")
}

model AuditLog {
  id            Int       @id @default(autoincrement())

  actorId       String?   @map("actor_id")
  actorEmail    String?   @map("actor_email")
  actorName     String?   @map("actor_name")
  actorRole     String?   @map("actor_role")

  action        String
  resource      String
  resourceId    String?   @map("resource_id")
  resourceLabel String?   @map("resource_label")

  before        Json?
  after         Json?

  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")

  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([actorId, createdAt])
  @@index([resource, resourceId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
  @@schema("public")
}

// ============================================================
// Wiki 모듈 (사내 위키)
//
// - 별도 PostgreSQL 스키마 `wiki`에 격리
// - FK 참조 방향: wiki.* → public.*  (반대 금지)
// - 코드 의존성: app/wiki/*, lib/wiki/* → 메인 OK / 메인 → 위키 금지
// ============================================================

model WikiPage {
  id           String   @id @default(uuid())
  parentId     String?  @map("parent_id")
  title        String
  slug         String?
  contentJson  Json     @map("content_json")
  isPublished  Boolean  @default(true) @map("is_published")
  sortOrder    Int      @default(0) @map("sort_order")
  authorId     String   @map("author_id")
  lastEditorId String?  @map("last_editor_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  plainText   String              @default("") @map("plain_text")
  icon         String? @map("icon")
  coverUrl     String? @map("cover_url")
  coverOffsetY Int     @default(50) @map("cover_offset_y")
  isTemplate   Boolean @default(false) @map("is_template")
  deletedAt    DateTime? @map("deleted_at")
  collabEnabled Boolean @default(false) @map("collab_enabled")
  pageType     String  @default("block") @map("page_type") @db.VarChar(10)
  contentHtml  String? @map("content_html")
  aiExcluded   Boolean @default(false) @map("ai_excluded")

  parent      WikiPage?           @relation("WikiPageTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    WikiPage[]          @relation("WikiPageTree")
  author      User                @relation("WikiPageAuthor", fields: [authorId], references: [id])
  lastEditor  User?               @relation("WikiPageLastEditor", fields: [lastEditorId], references: [id])
  attachments WikiAttachment[]
  references  WikiPageReference[]
  tags        WikiPageTag[]
  favorites   WikiFavorite[]
  viewLogs    WikiViewLog[]
  versions    WikiVersion[]
  comments    WikiComment[]
  outgoingLinks WikiPageLink[]    @relation("WikiPageLinkSource")
  backlinks     WikiPageLink[]    @relation("WikiPageLinkTarget")
  ydoc          WikiPageYdoc?

  @@index([parentId, sortOrder])
  @@index([updatedAt(sort: Desc)])
  @@index([authorId])
  @@map("wiki_pages")
  @@schema("wiki")
}

// 위키 실시간 동시편집(Yjs) 협업 문서 상태 — 편집 중 진실의 원천(Y.Doc 바이너리)
model WikiPageYdoc {
  pageId    String   @id @map("page_id")
  state     Bytes
  updatedAt DateTime @default(now()) @map("updated_at")

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@map("wiki_page_ydoc")
  @@schema("wiki")
}

model WikiPageLink {
  sourcePageId String @map("source_page_id")
  targetPageId String @map("target_page_id")

  source WikiPage @relation("WikiPageLinkSource", fields: [sourcePageId], references: [id], onDelete: Cascade)
  target WikiPage @relation("WikiPageLinkTarget", fields: [targetPageId], references: [id], onDelete: Cascade)

  @@id([sourcePageId, targetPageId])
  @@index([targetPageId])
  @@map("wiki_page_links")
  @@schema("wiki")
}

model WikiNotification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  pageId    String?   @map("page_id")
  type      String
  actorId   String?   @map("actor_id")
  actorName String?   @map("actor_name")
  pageTitle String?   @map("page_title")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, readAt, createdAt])
  @@map("wiki_notifications")
  @@schema("wiki")
}

model WikiAttachment {
  id         String   @id @default(uuid())
  pageId     String   @map("page_id")
  fileName   String   @map("file_name")
  s3Key      String   @unique @map("s3_key")
  size       Int
  mimeType   String   @map("mime_type")
  uploaderId String   @map("uploader_id")
  createdAt  DateTime @default(now()) @map("created_at")

  page     WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  uploader User     @relation("WikiAttachmentUploader", fields: [uploaderId], references: [id])

  @@index([pageId])
  @@map("wiki_attachments")
  @@schema("wiki")
}

model WikiPageReference {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  refType     String   @map("ref_type")
  refCode     String   @map("ref_code")
  createdById String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  page      WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  createdBy User     @relation("WikiPageRefCreator", fields: [createdById], references: [id])

  @@unique([pageId, refType, refCode])
  @@index([refType, refCode])
  @@index([pageId])
  @@map("wiki_page_references")
  @@schema("wiki")
}

model WikiTag {
  id        String        @id @default(uuid())
  name      String        @unique
  color     String?
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at")

  pages WikiPageTag[]

  @@map("wiki_tags")
  @@schema("wiki")
}

model WikiPageTag {
  pageId  String   @map("page_id")
  tagId   String   @map("tag_id")
  addedAt DateTime @default(now()) @map("added_at")

  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tag  WikiTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([pageId, tagId])
  @@index([tagId])
  @@map("wiki_page_tags")
  @@schema("wiki")
}

model WikiFavorite {
  userId    String   @map("user_id")
  pageId    String   @map("page_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User     @relation("WikiFavoriteUser", fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@id([userId, pageId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("wiki_favorites")
  @@schema("wiki")
}

model WikiViewLog {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  pageId   String   @map("page_id")
  viewedAt DateTime @default(now()) @map("viewed_at")

  user User     @relation("WikiViewLogUser", fields: [userId], references: [id], onDelete: Cascade)
  page WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt(sort: Desc)])
  @@index([pageId])
  @@map("wiki_view_logs")
  @@schema("wiki")
}

model WikiVersion {
  id          String   @id @default(uuid())
  pageId      String   @map("page_id")
  title       String
  contentJson Json     @map("content_json")
  savedById   String   @map("saved_by_id")
  savedAt     DateTime @default(now()) @map("saved_at")

  page    WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  savedBy User     @relation("WikiVersionSaver", fields: [savedById], references: [id])

  @@index([pageId, savedAt(sort: Desc)])
  @@map("wiki_versions")
  @@schema("wiki")
}

model WikiComment {
  id        String   @id @default(uuid())
  pageId    String   @map("page_id")
  authorId  String   @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  page   WikiPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User     @relation("WikiCommentAuthor", fields: [authorId], references: [id])

  @@index([pageId, createdAt])
  @@index([authorId])
  @@map("wiki_comments")
  @@schema("wiki")
}

// ===== 차량예약 =====

model Vehicle {
  id          Int      @id @default(autoincrement())
  name        String
  plateNumber String   @unique @map("plate_number")
  model       String?
  seatCount   Int?     @map("seat_count")
  color       String?
  memo        String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  lastOdometer Int?    @map("last_odometer")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  reservations VehicleReservation[]
  logs         VehicleLog[]

  @@map("vehicles")
  @@schema("public")
}

model VehicleReservation {
  id          Int      @id @default(autoincrement())
  vehicleId   Int      @map("vehicle_id")
  userId      String   @map("user_id")
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  purpose     String?
  destination String?
  status      String   @default("RESERVED")
  returnedAt  DateTime? @map("returned_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  user    User    @relation("VehicleReservationUser", fields: [userId], references: [id])
  log     VehicleLog?

  @@index([vehicleId, startAt])
  @@index([userId, startAt])
  @@map("vehicle_reservations")
  @@schema("public")
}

model VehicleLog {
  id            Int       @id @default(autoincrement())
  vehicleId     Int       @map("vehicle_id")
  reservationId Int?      @unique @map("reservation_id")
  driverId      String    @map("driver_id")
  startAt       DateTime  @map("start_at")
  endAt         DateTime  @map("end_at")
  purpose       String?
  destination   String?
  endOdometer   Int       @map("end_odometer")
  distanceKm    Int?      @map("distance_km")
  note          String?
  createdById   String    @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  vehicle     Vehicle             @relation(fields: [vehicleId], references: [id])
  reservation VehicleReservation? @relation(fields: [reservationId], references: [id])
  driver      User                @relation("VehicleLogDriver", fields: [driverId], references: [id])
  createdBy   User                @relation("VehicleLogCreator", fields: [createdById], references: [id])

  @@index([vehicleId, endAt])
  @@index([driverId, startAt])
  @@map("vehicle_logs")
  @@schema("public")
}

// ===== AI 어시스턴트 v2 (function_ai_assistant.html) =====

// 게이트웨이 배치 플래너 잡 (function_gateway_planner.html Phase 1)
model GatewayPlanJob {
  id            Int      @id @default(autoincrement())
  title         String   @db.VarChar(300)
  status        String   @default("PENDING") @db.VarChar(20) // PENDING|RASTERIZING|ANALYZING|NEED_SCALE|PLACED|ERROR
  originalKey   String   @map("original_key")
  originalName  String   @map("original_name") @db.VarChar(300)
  pageIndex     Int      @default(0) @map("page_index")
  pageCount     Int?     @map("page_count")
  imageKey      String?  @map("image_key") // 원본 해상도 PNG (PPTX 배경용)
  visionKey     String?  @map("vision_key") // 분석·미리보기용 축소 PNG (좌표 기준)
  imageWidth    Int?     @map("image_width")
  imageHeight   Int?     @map("image_height")
  visionWidth   Int?     @map("vision_width")
  visionHeight  Int?     @map("vision_height")
  scaleMPerPx   Float?   @map("scale_m_per_px") // 확정 스케일 (m / vision px)
  scaleSource   String?  @map("scale_source") @db.VarChar(20) // ai_dimension | manual_2point | none
  scaleMeta     Json?    @map("scale_meta") // AI 치수 후보·산포 등
  analysis      Json?    // 공간 인식 결과 (spaces[], vision 좌표)
  placements    Json?    // 배치 결과 (points[], vision 좌표)
  gatewayCount  Int?     @map("gateway_count")
  rulesSnapshot Json?    @map("rules_snapshot")
  pptxKey       String?  @map("pptx_key")
  errorMessage  String?  @map("error_message")
  tokenUsage    Json?    @map("token_usage")
  createdById   String   @map("created_by")
  createdBy     User     @relation("GatewayPlanJobCreator", fields: [createdById], references: [id])
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([createdById, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("gateway_plan_jobs")
  @@schema("public")
}

model AiChatSession {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id")
  hospitalCode String?  @map("hospital_code")
  title        String   @default("") @db.VarChar(80)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hospital Hospital?       @relation(fields: [hospitalCode], references: [hospitalCode])
  messages AiChatMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@map("ai_chat_sessions")
  @@schema("public")
}

model AiChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.Uuid
  role      String   @db.VarChar(10)
  content   String   @default("")
  toolCalls Json?    @map("tool_calls")
  usage     Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  session AiChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("ai_chat_messages")
  @@schema("public")
}
