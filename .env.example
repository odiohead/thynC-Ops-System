# =============================================================================
# thynC Operations System - 환경변수 예시
# 이 파일을 복사해서 .env.local (또는 .env)을 생성하고 실제 값을 채워주세요.
# 실제 값이 담긴 .env.local은 절대 git에 커밋하지 마세요.
# =============================================================================

# ------------------------------------------------------------------------------
# 데이터베이스
# ------------------------------------------------------------------------------
DATABASE_URL="postgresql://<user>:<password>@localhost:5432/<dbname>"

# ------------------------------------------------------------------------------
# 인증
# ------------------------------------------------------------------------------
JWT_SECRET="your-secret-key"

# ------------------------------------------------------------------------------
# 앱 이름 (사이드바·헤더에 표시)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="thynC Operations System"

# ------------------------------------------------------------------------------
# Google Drive (Service Account)
# Google Cloud Console에서 서비스 계정 JSON 키를 발급받아 한 줄로 변환 후 입력
# 변환 명령: cat your-service-account.json | tr -d '\n'
# ------------------------------------------------------------------------------
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...전체_JSON_한줄로..."}

# 업로드 대상 Google Drive 폴더 ID
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here
